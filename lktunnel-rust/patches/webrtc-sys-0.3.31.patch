diff -urN a/include/livekit/raw_bytes_transformer.h b/include/livekit/raw_bytes_transformer.h
--- a/include/livekit/raw_bytes_transformer.h	1970-01-01 01:00:00
+++ b/include/livekit/raw_bytes_transformer.h	2026-05-19 12:42:13
@@ -0,0 +1,87 @@
+/*
+ * raw_bytes_transformer.h — install a webrtc::FrameTransformerInterface
+ * on an RtpSender / RtpReceiver that *replaces* the encoded video payload
+ * with arbitrary bytes from Rust (sender), or extracts bytes from arriving
+ * frames and pushes them to a Rust callback (receiver).
+ *
+ * The transform sits between the encoder and the RTP packetizer on send,
+ * and between the depacketizer and the decoder on receive — same hook
+ * point LiveKit's E2EE uses (frame_cryptor.cpp:142,164). libwebrtc still
+ * handles SSRC/seq/timestamp/SRTP/MTU-chunking, so we ride RTP without
+ * having to reimplement any of that machinery.
+ *
+ * Why we need this: SCTP-over-DTLS (the data-channel transport) appears
+ * to be DPI-fingerprinted on some networks. RTP (Opus/VP8 over SRTP) is
+ * structurally indistinguishable from media calls and survives.
+ *
+ * Usage:
+ *   sender: new_raw_bytes_transformer_for_rtp_sender(sender)
+ *             → call .send(bytes) to enqueue. The next Transform() call
+ *               from the encoder pulls one packet and forwards it.
+ *   receiver: new_raw_bytes_transformer_for_rtp_receiver(receiver, obs)
+ *             → on each arriving frame, obs->on_data(bytes) fires. The
+ *               frame is dropped (decoder never runs on the garbage).
+ */
+#pragma once
+
+#include <atomic>
+#include <deque>
+#include <map>
+#include <memory>
+#include <mutex>
+#include <optional>
+#include <vector>
+
+#include "api/frame_transformer_interface.h"
+#include "api/scoped_refptr.h"
+#include "livekit/rtp_receiver.h"
+#include "livekit/rtp_sender.h"
+#include "rust/cxx.h"
+
+namespace livekit_ffi {
+
+class RawBytesObserverWrapper;
+
+class RawBytesFrameTransformerImpl;
+
+// Thin std::shared_ptr-friendly handle around the underlying
+// webrtc::scoped_refptr<FrameTransformerInterface> so cxx can hold it.
+class RawBytesFrameTransformer {
+ public:
+  RawBytesFrameTransformer(
+      webrtc::scoped_refptr<RawBytesFrameTransformerImpl> impl);
+  ~RawBytesFrameTransformer();
+
+  // Sender-side only: enqueue a packet. Returns false if the queue is
+  // full (caller's responsibility to drop / retry). On the receiver side
+  // this always returns false.
+  bool send(rust::Slice<const uint8_t> data) const;
+
+  // Sender-side: current queue depth. Useful for backpressure.
+  size_t queue_depth() const;
+
+ private:
+  webrtc::scoped_refptr<RawBytesFrameTransformerImpl> impl_;
+};
+
+// Allocate a sender-side transformer and install it on `sender` via
+// SetEncoderToPacketizerFrameTransformer. The encoder still runs (which
+// is required to drive Transform() calls); the encoded video output is
+// discarded and replaced with whatever bytes the caller has enqueued.
+std::shared_ptr<RawBytesFrameTransformer>
+new_raw_bytes_transformer_for_rtp_sender(std::shared_ptr<RtpSender> sender);
+
+// Allocate a receiver-side transformer and install it on `receiver` via
+// SetDepacketizerToDecoderFrameTransformer. Each arriving frame fires
+// observer->on_data with the raw bytes (no decode pass).
+std::shared_ptr<RawBytesFrameTransformer>
+new_raw_bytes_transformer_for_rtp_receiver(
+    std::shared_ptr<RtpReceiver> receiver,
+    rust::Box<RawBytesObserverWrapper> observer);
+
+static std::shared_ptr<RawBytesFrameTransformer> _shared_raw_bytes_transformer() {
+  return nullptr;  // Ignore — cxx shared_ptr helper, same pattern as
+                   // _shared_rtp_sender in rtp_sender.h.
+}
+
+}  // namespace livekit_ffi
