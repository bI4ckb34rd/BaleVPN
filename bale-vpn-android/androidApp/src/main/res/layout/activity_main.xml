<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="24dp" android:gravity="center_horizontal">

    <ImageView
        android:layout_width="100dp" android:layout_height="100dp"
        android:src="@drawable/ic_title"
        android:layout_gravity="center_horizontal"
        android:scaleType="fitCenter"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Bale VPN"
        android:textSize="26sp" android:textStyle="bold"
        android:layout_marginBottom="2dp"/>

    <!-- Logged-in account name. Populated once BaleWsClient.loadSelf() resolves. -->
    <TextView
        android:id="@+id/tvSelfName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="13sp" android:alpha="0.6"
        android:layout_marginBottom="20dp"
        android:visibility="gone"/>

    <!-- ── Main card ─────────────────────────────────────────────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <!-- WS status + connect — shared by both modes -->
        <TextView android:id="@+id/tvWsStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:alpha="0.6"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWs"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Connect"
            android:visibility="gone"/>

        <!-- Mode toggle — exactly one must always be selected -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleMode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModeClient"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Client"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModeServer"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Server"/>

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- ── CLIENT section ──────────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutClient"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:id="@+id/tvPeer"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="15sp" android:alpha="0.7"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectPeer"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Select Peer"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVpn"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Start VPN"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <TextView android:id="@+id/tvStats"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="12sp" android:alpha="0.6"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ── SERVER section ──────────────────────────────────────────── -->
        <LinearLayout android:id="@+id/layoutServer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:id="@+id/tvServerStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Server Inactive"
                android:textSize="15sp" android:alpha="0.7"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tvContactNote"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="ⓘ Bale only allows calls between contacts. Anyone who wants to connect through you must already be in your contact list."
                android:textSize="12sp" android:alpha="0.7"
                android:layout_marginBottom="12dp"
                android:padding="8dp"
                android:background="?android:attr/colorBackground"/>

            <!-- Pending connection requests -->
            <TextView android:id="@+id/tvPendingHeader"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pending Requests"
                android:textSize="13sp" android:alpha="0.6"
                android:layout_marginBottom="4dp"
                android:visibility="gone"/>

            <LinearLayout android:id="@+id/llPending"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageContacts"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Contacts"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageAdmission"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Manage Clients"/>

        </LinearLayout>

    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Logout — outside the card -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Logout"/>

</LinearLayout>
</ScrollView>
