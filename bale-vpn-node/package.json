{
  "name": "bale-vpn-node",
  "version": "1.0.0",
  "description": "Bale messenger protobuf message codecs",
  "main": "src/index.js",
  "bin": "src/bale-proxy.js",
  "scripts": {
    "build": "npx pbjs -t static-module -w commonjs -o src/messages.js proto/*.proto && npx pbts -o src/messages.d.ts src/messages.js",
    "build:native": "../lktunnel-rust/patches/apply.sh && cd rust/lktunnel-node && npm run build",
    "ui": "node src/bale-proxy.js",
    "package": "pkg . --out-path dist"
  },
  "pkg": {
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "rust/lktunnel-node/*.node",
      "rust/lktunnel-node/index.js"
    ]
  },
  "dependencies": {
    "protobufjs": "^7.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "pkg": "^5.8.1"
  }
}
